<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	   xmlns:context="http://www.springframework.org/schema/context"
	   xsi:schemaLocation="http://www.springframework.org/schema/beans
  		    http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
  		    http://www.springframework.org/schema/context
  		    http://www.springframework.org/schema/context/spring-context-3.0.xsd">

	<!-- Only register OAuth2BeanFactory for oauth2.properties.
	     Exclude all controllers and other beans to avoid Spring Security dependencies. -->
	<context:component-scan base-package="org.openmrs.module.oauth2login.web.controller"
						    use-default-filters="false">
		<context:include-filter type="assignable"
			expression="org.openmrs.module.oauth2login.web.controller.OAuth2BeanFactory"/>
	</context:component-scan>

</beans>
